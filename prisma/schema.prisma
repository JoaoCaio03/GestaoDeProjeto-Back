generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  idUser        Int        @id @default(autoincrement())
  name          String     @db.VarChar(100)
  email         String     @unique @db.VarChar(100)
  password_hash String     @db.VarChar(255)
  role          UserRole   @default(VIEWER)
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamp(0)
  contracts     Contract[]

  @@map("USERS")
}

model Document {
  idDocument Int      @id @default(autoincrement())
  fileName   String   @db.VarChar(255)
  fileKey    String   @db.Text
  fileUrl    String   @db.Text
  mimeType   String   @db.VarChar(50)
  docType    DocType  @default(OUTROS)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  idContract Int?      @map("id_contract")
  contract   Contract? @relation(fields: [idContract], references: [idContracts], onDelete: NoAction)

  idAdditive Int?      @map("id_additive")
  additive   Additive? @relation(fields: [idAdditive], references: [idAdditive], onDelete: NoAction)

  idApostille Int?       @map("id_apostille")
  apostille   Apostille? @relation(fields: [idApostille], references: [idApostille], onDelete: NoAction)

  @@map("DOCUMENTS")
}

// --- CONTRATOS ---

model Contract {
  idContracts   Int            @id @default(autoincrement())
  contractNum   String         @unique @db.VarChar(50)
  objects       String         @db.Text
  contractor    String         @db.VarChar(150)
  contractValue Decimal        @db.Decimal(15, 2)
  startDate     DateTime       @map("start_date") @db.Date
  endDate       DateTime       @map("end_date") @db.Date
  status        ContractStatus @default(ATIVO)
  category      Category

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  // Relacionamentos
  createdByIdUser Int?  @map("id_user")
  createdByUser   User? @relation(fields: [createdByIdUser], references: [idUser], onDelete: NoAction)

  additives  Additive[]
  documents  Document[] // Aqui estarão vinculados o CONTRATO_PRINCIPAL e a ATA_REGISTRO_PRECO
  apostilles Apostille[]

  @@map("CONTRACTS")
}

// --- ADITIVOS ---

model Additive {
  idAdditive   Int          @id @default(autoincrement())
  typeAdditive AdditiveType
  description  String       @db.Text
  valueChange  Decimal?     @default(0.00) @db.Decimal(15, 2)
  newEndDate   DateTime?    @db.Date
  dateSigned   DateTime     @db.Date
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamp(0)

  // Relacionamentos
  idContract Int      @map("id_contract")
  contract   Contract @relation(fields: [idContract], references: [idContracts], onDelete: NoAction)

  documents Document[]

  @@map("ADDITIVES")
}

// --- APOSTILAMENTO ---

model Apostille {
  idApostille    Int      @id @default(autoincrement())
  supplierName   String   @db.VarChar(255)
  orderApostille Int      @db.SmallInt // Representa a ordem (1 a 10)
  dateApostille  DateTime @db.Date
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  // Relacionamentos
  idContract Int      @map("id_contract")
  contract   Contract @relation(fields: [idContract], references: [idContracts], onDelete: NoAction)

  documents Document[]

  @@map("APOSTILLE")
}

// --- ENUMERATIONS ---

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

enum ContractStatus {
  ATIVO
  SUSPENSO
  ENCERRADO
  ATENCAO
}

enum Category {
  MATERIAL
  SERVICOS
  LOCACAO_DE_IMOVEL
  TECNOLOGIA
  OBRAS
  CONSULTORIA
  OUTROS
}

enum AdditiveType {
  Aditivo_de_Prazo
  Aditivo_de_Valor
}

enum DocType {
  CONTRATO_PRINCIPAL
  ATA_REGISTRO
  APOSTILAMENTO
  ADITIVO
  DOCUMENTO_AUXILIAR
  OUTROS
}
